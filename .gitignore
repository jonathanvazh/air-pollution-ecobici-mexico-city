# Python virtual environment (rebuilt from uv.lock — never commit)
.venv/

# Python caches
__pycache__/
*.pyc

# DuckDB database files (can be large; rebuilt from raw data)
*.duckdb
*.duckdb.wal

# Raw / heavy data: ignore the contents...
data/**
# ...but let Git traverse the folders...
!data/**/
# ...and keep the provenance docs (SOURCE.md, etc.)
!data/**/*.md

# Quarto build output and cache
/_site/
/.quarto/

# OS noise
.DS_Store
Thumbs.db
**/*.quarto_ipynb
